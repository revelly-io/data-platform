# Copy to .env.local (gitignored). Used by Spark (--env local) and docker compose.

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

S3A_ACCESS_KEY=minioadmin
S3A_SECRET_KEY=minioadmin
S3A_ENDPOINT=http://localhost:9000

POSTGRES_USER=iceberg
POSTGRES_PASSWORD=iceberg
POSTGRES_DB=iceberg

ICEBERG_REST_URI=http://localhost:8181

# Required by Iceberg S3FileIO (MinIO accepts any region)
AWS_REGION=us-east-1
